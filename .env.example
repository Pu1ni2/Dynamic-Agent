OPENAI_API_KEY="your_openai_api_key_here"
MAX_ROUNDS=3

# ── Optional: MCP server config ────────────────────────────────────
# MCP_CONFIG_PATH="mcp_servers.json"

# ── Optional: Email (SMTP) ─────────────────────────────────────────
# Enables agents to send REAL emails. Works with Gmail, Outlook, etc.
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="you@gmail.com"
# SMTP_PASS="your_app_password"
# SMTP_FROM="you@gmail.com"

# ── Optional: Slack ────────────────────────────────────────────────
# Enables agents to post REAL messages to Slack channels.
# Create a webhook: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"

# ── Optional: Google Calendar ──────────────────────────────────────
# For advanced calendar integration (service account JSON path)
# GOOGLE_CALENDAR_CREDENTIALS="path/to/service-account.json"
# Note: .ics file creation works WITHOUT this — files can be imported
# into any calendar app manually.
